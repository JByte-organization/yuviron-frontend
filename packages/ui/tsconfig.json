{
  "extends": "@repo/typescript-config/base.json", // Твой базовый конфиг
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"], // Добавляем типы Vite здесь!
    "esModuleInterop": true // Это исправит ошибку с импортом path
  },
  "include": ["index.ts", "src/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}